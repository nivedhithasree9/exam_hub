PORT=5000
# Set either MYSQL_URI or the separate variables below.
# If your password contains @ or other special characters, use MYSQL_PASSWORD instead of MYSQL_URI.
MYSQL_URI=mysql://root:password@127.0.0.1:3306/examhub
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=examhub
